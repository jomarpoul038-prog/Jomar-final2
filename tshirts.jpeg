elHeadingDefault":"Sorry","errorPanelHeadingAPIError":"We apologize for the inconvenience!","errorPanelHeadingNoLocation":"Location Services are turned off.","errorPanelDescriptionDefault":"Unable to locate stores in this area. Search another location for options nearby.","errorPanelDescriptionAPIError":"Unable to load content. Please try again later or contact Customer Service.","errorPanelDescriptionNoLocation":"To locate the nearest H\u0026M store, please turn on Location Services.","ctaTextDefault":"Change store","labelTextFindInStore":"Find at:","heading":"Select store","storesAreaMetaText":"For free same day pick-up, please order online by 4pm.","changeStoreWarningTitle":"Apologies, store pick-up is limited to one location per order.","changeStoreWarningDescription":"Some items in your shopping bag may be unavailable at this store location. To have them delivered to your door instead, please change the delivery method during checkout.","changeStoreInfo":"Change store","bopisInStore":"In-store","locationSettings":"Location settings","addToBagWarningText":"Please be aware this might not be available for in-store pickup if you checkout later.","conceptsTiltleAriaLabel":"Departments available in this store.","singleStoreCustomerServiceAriaLabel":"Call customer service: {0}","exceptionalHoursAriaLabel":"Exceptional store hours.","locationSettingsBtnAriaLabel":"Open device location settings.","changeStoreBtnAriaLabel":"Confirm change store.","selectedSizeAriaLabel":"Availability for selected size at {0}:{1}","selectStoreBtnAriaLabel":"Confirm {0} for free in-store pickup.","findAtAriaLabel":"Find product at {0}.","sizeUnavailableAriaLabel":"{0} is unavailable at {1}. More delivery methods available during checkout.","sizeAvailableAriaLabel":"{0} available for free pick-up at {1}","freePickUpAriaLabel":"Free pick-up at {0}","checkboxEnableAriaLabel":"Enable “Free pick-up in-store” for this product.","changeStoreAriaLabel":"Change store pick-up location.","checkboxDisableAriaLabel":"Disable pick up in-store for this product.","findAStoreAriaLabel":"Check in-store availability","recentSearchedAriaLabel":"You have {0} search history result","bopisHeadingAriaLabel":"Find In-Store or Buy Online, Pick Up In-Store","selectStoreAriaLabel":"Select store: {0}","fisPickupTypeAriaLabel":"Available to buy in-store only at {0}","storeExpandAriaLabel":"Expand store details for {0}","selectedStoreAriaLabel":"Selected store: {0}","storeAddressAriaLabel":"Store address: {0}","bopisPickupTypeAriaLabel":"Buy online and pick up in-store is available at {0}","storeCloseBtnAriaLabel":"Collapse store details for {0}","openingHoursAriaLabel":"Store hours for {0}","storeInfoAriaLabel":"Store information. Open store page for more information about {0}","directionsAriaLabel":"Get directions to {0} with Google Maps.","changeStoreModalHeadingAriaLabel":"Change store selection.","locationErrorHeadingAriaLabel":"Location services are turned off.","locationErrorDescritpionAriaLabel":"To find the nearest H\u0026M stores, please enable location services.","inStockAriaLabel":"Size {0}: In stock.","fewPiecesLeftAriaLabel":"Size {0}: Limited stock remaining.","outOfStockAriaLabel":"Size {0}: Out of stock."},"bopisUS":{"heading":"Select a pickup store","autocompletePlaceholder":"Search by ZIP code or city","outOfStockText":"Out of stock","openingHoursTitle":"Opening hours","availableLegend":"Available","outOfStockLegend":"Out of stock","changeStoreText":"Change store","selectStoreText":"Select store","pickUpTiltleText":"Free same-day pickup in-store","pickUpAtText":"Pick up at","pickUpDisabledText":"Not available for same-day pickup in-store","pickUpNotAvailableText":"This item is not available at","changeStoreModalTitleText":"Change store?","changeStoreModalDescriptionText":"bopis.switchStore.description","changeStoreModalButtonText":"Change to this store","changeStoreCancelText":"Cancel","addToBagText":"Add to bag","selectStoreButtonText":"Select store","addToBagWarningNotificationText":"bopis.pdp.addToCart.warning","errorPanelHeadingDefault":"Sorry","errorPanelHeadingAPIError":"We apologize for the inconvenience!","errorPanelHeadingNoLocation":"Location Services are turned off.","errorPanelDescriptionDefault":"Unable to locate stores in this area. Search another location for options nearby.","errorPanelDescriptionAPIError":"Unable to load content. Please try again later or contact Customer Service.","errorPanelDescriptionNoLocation":"To locate the nearest H\u0026M store, please turn on Location Services.","selectedSizeLabel":"Selected size","selectedStoreText":"pdp.bopis.selected.store","selectedText":"pdp.bopis.selected"},"p1StoreShip":{"labelText":"Item ships for {0} with next-day delivery. Free store pick-up is also available.","labelTextNotLoggedIn":"Ships for {0} in {1}-{2} business day(s). See eligibility at checkout. Free in-store pickup is also available."},"productlisting":{"clear":"Clear","filterBy":"Filter by"},"giftCard":{"servicedown":"Service Down"},"sustainability":{"starterButton":"Product background","modalTitle":"Product background","introText":"We believe that greater transparency will help lead the change towards a more sustainable future. As a step in this long-term commitment, we’re sharing how and where our products are made wherever possible. ","introTextNoSuppliers":"We believe that greater transparency will help lead the change towards a more sustainable fashion future. As a first step in this long-term commitment, we’re sharing how our products are made wherever possible.","materials":{"headerText":"Materials","bodyText":"Our goal is to use 100% recycled or other sustainably sourced materials by 2030."},"suppliers":{"headerText":"Our suppliers","backText":"Back","bodyTextCountryList":"This product has been produced in one of the following countries:","buttonSeeAllText":"Suppliers and factories for this product.","introText":"All our products are made by independent suppliers, often in developing countries where our presence can make a real difference. Our business helps to create jobs and independence, particularly for women — consequently lifting people out of poverty and contributing to economic growth. We only work with partners who share our respect for people and the environment, and who are willing to work with us to improve their practices. All suppliers and factories must sign our strict Sustainability Commitment, which includes requirements for fair wages and good working conditions for all. We employ dedicated sustainability staff in our worldwide production offices to make sure the commitment is followed.","sorryText":"Unfortunately, supplier and factory information isn’t currently available for this product. Thank you for being patient while we work towards displaying these details for all H\u0026M items possible.","modalTitle":"Supplier \u0026 factory list","workersAmount":"Number of workers:","disclaimerTop":"These suppliers and factories made this product for H\u0026M globally, which means that the item you will receive is produced by one of these suppliers and one of their factories.","disclaimerLabelsupplierAndFactoryExplanationText":"We want to be completely transparent with you about how and where our products are made, and we have a new system for this.","disclaimerLabelsupplierAndFactoryExplanationText_2":"However, if an item was produced before we started using our new system, all the supplier information may not be available. We’re focussing our efforts on making sure all items going forwards display all supplier details.","disclaimerLabelsupplierAndFactoryExplanationText_3":"If we stop working with a supplier or factory, we’ll only display the last information that we had at the point of collaboration.","disclaimerLabelsupplierAndFactoryExplanationText_4":"Thank you for bearing with us while we work towards greater transparency.","supplierInformationText1":"Independent suppliers make all our products in many parts of the world. Suppliers and factories who work with us must sign our Sustainability Commitment, and we employ staff in our worldwide production offices to ensure the commitment is followed.","supplierInformationText2":"If you want to learn more about our Sustainability Commitment, and our work with suppliers and factories in general, visit “Standards \u0026 policies” at hmgroup.com.","supplierInformationText3":"As for now, we can only share this information for H\u0026M products."},"NewMaterialAccordion":{"additionalMaterialsIntro":"The total weight of this product contains at least","additionalMaterialsExplanation":"We exclude the weight of minor components such as, but not exclusively: threads, buttons, zippers, embellishments and prints.","additionalMaterialsCalculation":"The total weight of the product is calculated by adding the weight of all layers and main components together. Based on that, we calculate how much of that weight is made out by each material. For sets \u0026 multipacks all pieces are counted together as one product in calculations."},"fashionRecycler":{"headerText":"Be a fashion recycler!","bodyText":"Bring your clean, previously loved clothing or textiles to one of our stores — they can be from any brand."},"certificationInformation":"Certification information"},"strength":{"bad":"Weak","medium":"Good","strong":"Strong"},"colorSelector":{"swatch.alt.text.outofstock":"{0} is out of stock","variant.title.fragrance":"Fragrance","variant.title.color":"Color","hide.colors":"Show less","hide.fragrances":"Show less","variant.carousel.previous":"Previous","variant.carousel.next":"Next","carousel.alt.text":"Carousel of variants"}},"dataSource":"Hybris"},"sizeSelectorDataObj":{"sizeGuideDomainUrl":"https://api.hm.com"},"direction":"ltr"}},"__N_SSP":true},"page":"/productpage/[articleId]","query":{"articleId":"1328845004"},"buildId":"/northstar-pdp-6e7eca339001fc8d9c61530421d263759dafaf1f","assetPrefix":"/northstar-pdp","runtimeConfig":{"basePath":""},"isFallback":false,"is